#!/bin/sh
#
# swarm-msg - Inter-agent messaging tool for swarm communication
#
# Usage:
#   swarm-msg send <agent> <message>       Send message via file outbox (preferred)
#   swarm-msg send <agent> -f <file>       Send file contents via outbox
#   swarm-msg ask <object> <message>       Send AND WAIT for the object's reply
#   swarm-msg broadcast <message>          Broadcast to all connected agents
#   swarm-msg list                         List available agents (from topology)
#   swarm-msg send-stdout <agent> <msg>    Legacy: send via stdout protocol
#   swarm-msg help                         Show this help
#

set -e

# Legacy stdout delimiters (used by send-stdout)
MSG_START="<<SWARM_MSG"
MSG_END="<<SWARM_MSG:END>>"

show_help() {
    cat << 'EOF'
swarm-msg - Inter-agent messaging for swarm communication

USAGE:
    swarm-msg send <agent> <message>       Send message to an agent (via outbox)
    swarm-msg send <agent> -f <file>       Send file contents to an agent
    swarm-msg ask <object> <message>       Send AND WAIT for the object's reply
    swarm-msg broadcast <message>          Broadcast to all connected agents
    swarm-msg list                         List agents you can message
    swarm-msg send-stdout <agent> <msg>    Legacy: send via stdout protocol
    swarm-msg help                         Show this help

EXAMPLES:
    # Send a JSON message
    swarm-msg send fixer_pool '{"action":"fix_result","status":"fixed"}'

    # Ask an object and get its reply inline (synchronous):
    swarm-msg ask browse '{"action":"render","url":"https://example.com/"}'

    # Send state report
    swarm-msg send metrics '{"action":"state_report","data":{"state":{"count":42}}}'

    # Broadcast to all connected agents
    swarm-msg broadcast "Phase complete, ready for next"

    # Send file contents
    swarm-msg send verifier -f /workspace/fix.patch

NOTES:
    Messages are written to /workspace/.outbox/ and picked up by the swarm
    router automatically. Agent names: agent_1, explorer, implementer, etc.
    Use 'list' to see agents in your topology.

    'ask' blocks until the object's reply arrives and prints a JSON envelope:
      {"ok":true,"result":{...},"error":null,"timeout":false,...}
      {"ok":false,"error":{"code":"...","type":"permanent|transient"},...}
    On timeout (SWARM_ASK_TIMEOUT seconds, default 30) it prints an
    ok:false/timeout:true envelope. An error.type of "permanent" means
    retrying the same ask can never succeed.
EOF
}

# Outbox-based send (default) — writes JSON to /workspace/.outbox/
send_message() {
    to="$1"
    shift

    message=""
    file=""

    # Parse arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--file)
                file="$2"
                shift 2
                ;;
            -m|--message)
                message="$2"
                shift 2
                ;;
            *)
                if [ -z "$message" ]; then
                    message="$1"
                fi
                shift
                ;;
        esac
    done

    if [ -z "$to" ]; then
        echo "Error: No target agent specified" >&2
        exit 1
    fi

    if [ -z "$message" ] && [ -z "$file" ]; then
        echo "Error: No message or file specified" >&2
        exit 1
    fi

    # Build content
    content="$message"
    if [ -n "$file" ] && [ -f "$file" ]; then
        if [ -n "$message" ]; then
            content="${message}

--- FILE: $(basename "$file") ---
$(cat "$file")"
        else
            content="$(cat "$file")"
        fi
    fi

    # Write to outbox
    outbox_dir="${OUTBOX_DIR:-/workspace/.outbox}"
    mkdir -p "$outbox_dir"
    # seq is an ordering hint only; a unique suffix (PID + nanosecond time)
    # prevents the filename collision/overwrite that the racy count-based seq
    # alone caused when two sends ran concurrently.
    seq=$(ls "$outbox_dir"/*.json 2>/dev/null | wc -l)
    seq=$((seq + 1))
    uniq="$$_$(date +%s%N 2>/dev/null || date +%s)"
    filename=$(printf "%04d_%s_%s.json" "$seq" "$to" "$uniq")

    # JSON-encode the content safely. `|| true` keeps a missing/failing jq from
    # aborting the script under `set -e` so the sed fallback below can run.
    encoded=$(printf '%s' "$content" | jq -Rs . 2>/dev/null) || true
    if [ -z "$encoded" ]; then
        # Fallback: escape with sed
        encoded="\"$(printf '%s' "$content" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g' | awk '{printf "%s\\n", $0}' | sed 's/\\n$//')\""
    fi

    # Write to a temp name (not *.json, so the watcher skips it) then atomically
    # rename into place — the watcher never reads a half-written file.
    tmpfile="$outbox_dir/.tmp_${uniq}"
    printf '{"to":"%s","content":%s}\n' "$to" "$encoded" > "$tmpfile"
    mv -f "$tmpfile" "$outbox_dir/$filename"
}

# Synchronous ask — like send, but carries a reply_to correlation id and BLOCKS
# until the engine writes the object's reply envelope to
# $ASK_REPLY_DIR/<corr>.json (default /workspace/.inbox/replies/). Prints the
# envelope to stdout, so a shell-tool caller receives the result inline in the
# same turn. On timeout prints an ok:false/timeout:true envelope — the output
# is ALWAYS one well-formed JSON envelope.
ask_message() {
    to="$1"
    shift

    message=""
    file=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--file)
                file="$2"
                shift 2
                ;;
            -m|--message)
                message="$2"
                shift 2
                ;;
            *)
                if [ -z "$message" ]; then
                    message="$1"
                fi
                shift
                ;;
        esac
    done

    if [ -z "$to" ]; then
        echo "Error: No target object specified" >&2
        exit 1
    fi

    if [ -z "$message" ] && [ -z "$file" ]; then
        echo "Error: No message or file specified" >&2
        exit 1
    fi

    content="$message"
    if [ -n "$file" ] && [ -f "$file" ]; then
        if [ -n "$message" ]; then
            content="${message}

--- FILE: $(basename "$file") ---
$(cat "$file")"
        else
            content="$(cat "$file")"
        fi
    fi

    # Correlation id: generated locally (safe charset by construction); becomes
    # the reply file name the engine writes to.
    corr="ask_$$_$(date +%s%N 2>/dev/null || date +%s)"
    reply_dir="${ASK_REPLY_DIR:-/workspace/.inbox/replies}"
    reply_file="$reply_dir/$corr.json"
    mkdir -p "$reply_dir"

    outbox_dir="${OUTBOX_DIR:-/workspace/.outbox}"
    mkdir -p "$outbox_dir"
    seq=$(ls "$outbox_dir"/*.json 2>/dev/null | wc -l)
    seq=$((seq + 1))
    uniq="$$_$(date +%s%N 2>/dev/null || date +%s)"
    filename=$(printf "%04d_%s_%s.json" "$seq" "$to" "$uniq")

    encoded=$(printf '%s' "$content" | jq -Rs . 2>/dev/null) || true
    if [ -z "$encoded" ]; then
        encoded="\"$(printf '%s' "$content" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g' | awk '{printf "%s\\n", $0}' | sed 's/\\n$//')\""
    fi

    # Atomic write (tmp + rename), same as send_message.
    tmpfile="$outbox_dir/.tmp_${uniq}"
    printf '{"to":"%s","content":%s,"reply_to":"%s"}\n' "$to" "$encoded" "$corr" > "$tmpfile"
    mv -f "$tmpfile" "$outbox_dir/$filename"

    # Block until the engine writes the reply envelope (atomic rename, so an
    # existing file is always complete), or until the timeout. The timeout
    # must be a positive integer: anything else would crash the arithmetic
    # below AFTER the ask was already published, breaking the
    # one-well-formed-envelope stdout contract — fall back to the default.
    timeout="${SWARM_ASK_TIMEOUT:-30}"
    case "$timeout" in
        ''|*[!0-9]*) timeout=30 ;;
    esac
    start=$(date +%s)
    while :; do
        if [ -f "$reply_file" ]; then
            cat "$reply_file"
            rm -f "$reply_file"
            return 0
        fi
        now=$(date +%s)
        if [ $((now - start)) -ge "$timeout" ]; then
            break
        fi
        sleep 0.1 2>/dev/null || sleep 1
    done

    # NOTE: $to is deliberately NOT interpolated into the message — it is
    # model-supplied and could contain a quote, breaking the envelope JSON.
    # $timeout and $corr are validated/generated above (digits / safe charset).
    elapsed_ms=$(( ($(date +%s) - start) * 1000 ))
    printf '{"ok":false,"result":null,"error":{"code":"timeout","message":"no reply within %s seconds","type":"transient"},"timeout":true,"correlation_id":"%s","duration_ms":%d}\n' \
        "$timeout" "$corr" "$elapsed_ms"
}

broadcast_message() {
    message="$1"
    if [ -z "$message" ]; then
        echo "Error: No message specified" >&2
        exit 1
    fi

    outbox_dir="${OUTBOX_DIR:-/workspace/.outbox}"
    mkdir -p "$outbox_dir"
    seq=$(ls "$outbox_dir"/*.json 2>/dev/null | wc -l)
    seq=$((seq + 1))
    uniq="$$_$(date +%s%N 2>/dev/null || date +%s)"
    filename=$(printf "%04d_broadcast_%s.json" "$seq" "$uniq")

    # `|| true`: a missing/failing python3 must not abort the script under
    # `set -e`; the sed fallback below handles the encoding.
    encoded=$(printf '%s' "$message" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null) || true
    if [ -z "$encoded" ]; then
        encoded="\"$(printf '%s' "$message" | sed 's/\\/\\\\/g; s/"/\\"/g' | tr '\n' ' ')\""
    fi

    # Temp name then atomic rename (see send_message) — unique suffix avoids the
    # racy-seq collision; the watcher only reads the final *.json.
    tmpfile="$outbox_dir/.tmp_${uniq}"
    printf '{"broadcast":true,"content":%s}\n' "$encoded" > "$tmpfile"
    mv -f "$tmpfile" "$outbox_dir/$filename"
}

# Legacy stdout protocol (kept for backward compatibility)
send_stdout() {
    to="$1"
    shift
    message="$*"

    if [ -z "$to" ] || [ -z "$message" ]; then
        echo "Error: Usage: swarm-msg send-stdout <agent> <message>" >&2
        exit 1
    fi

    echo "${MSG_START}:TO=${to}:START>>"
    echo "$message"
    echo "${MSG_END}"
}

broadcast_stdout() {
    message="$1"
    if [ -z "$message" ]; then
        echo "Error: Usage: swarm-msg broadcast-stdout <message>" >&2
        exit 1
    fi

    echo "${MSG_START}:BROADCAST:START>>"
    echo "$message"
    echo "${MSG_END}"
}

list_agents() {
    if [ -n "$SWARM_TOPOLOGY" ]; then
        echo "Agents you can message:"
        echo "$SWARM_TOPOLOGY" | tr ',' '\n' | sed 's/^/  - /'
    else
        echo "Topology not available."
    fi
}

# Main command dispatch
case "${1:-help}" in
    send)
        shift
        send_message "$@"
        ;;
    ask)
        shift
        ask_message "$@"
        ;;
    broadcast)
        shift
        broadcast_message "$@"
        ;;
    send-stdout)
        shift
        send_stdout "$@"
        ;;
    broadcast-stdout)
        shift
        broadcast_stdout "$@"
        ;;
    list)
        list_agents
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Unknown command: $1" >&2
        echo "Run 'swarm-msg help' for usage" >&2
        exit 1
        ;;
esac
