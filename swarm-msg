#!/bin/sh
#
# swarm-msg - Inter-agent messaging tool for swarm communication
#
# Usage:
#   swarm-msg send <agent> <message>       Send message via file outbox (preferred)
#   swarm-msg send <agent> -f <file>       Send file contents via outbox
#   swarm-msg broadcast <message>          Broadcast to all connected agents
#   swarm-msg list                         List available agents (from topology)
#   swarm-msg send-stdout <agent> <msg>    Legacy: send via stdout protocol
#   swarm-msg help                         Show this help
#

set -e

# Legacy stdout delimiters (used by send-stdout)
MSG_START="<<SWARM_MSG"
MSG_END="<<SWARM_MSG:END>>"

show_help() {
    cat << 'EOF'
swarm-msg - Inter-agent messaging for swarm communication

USAGE:
    swarm-msg send <agent> <message>       Send message to an agent (via outbox)
    swarm-msg send <agent> -f <file>       Send file contents to an agent
    swarm-msg broadcast <message>          Broadcast to all connected agents
    swarm-msg list                         List agents you can message
    swarm-msg send-stdout <agent> <msg>    Legacy: send via stdout protocol
    swarm-msg help                         Show this help

EXAMPLES:
    # Send a JSON message
    swarm-msg send fixer_pool '{"action":"fix_result","status":"fixed"}'

    # Send state report
    swarm-msg send metrics '{"action":"state_report","data":{"state":{"count":42}}}'

    # Broadcast to all connected agents
    swarm-msg broadcast "Phase complete, ready for next"

    # Send file contents
    swarm-msg send verifier -f /workspace/fix.patch

NOTES:
    Messages are written to /workspace/.outbox/ and picked up by the swarm
    router automatically. Agent names: agent_1, explorer, implementer, etc.
    Use 'list' to see agents in your topology.
EOF
}

# Outbox-based send (default) — writes JSON to /workspace/.outbox/
send_message() {
    to="$1"
    shift

    message=""
    file=""

    # Parse arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--file)
                file="$2"
                shift 2
                ;;
            -m|--message)
                message="$2"
                shift 2
                ;;
            *)
                if [ -z "$message" ]; then
                    message="$1"
                fi
                shift
                ;;
        esac
    done

    if [ -z "$to" ]; then
        echo "Error: No target agent specified" >&2
        exit 1
    fi

    if [ -z "$message" ] && [ -z "$file" ]; then
        echo "Error: No message or file specified" >&2
        exit 1
    fi

    # Build content
    content="$message"
    if [ -n "$file" ] && [ -f "$file" ]; then
        if [ -n "$message" ]; then
            content="${message}

--- FILE: $(basename "$file") ---
$(cat "$file")"
        else
            content="$(cat "$file")"
        fi
    fi

    # Write to outbox
    outbox_dir="${OUTBOX_DIR:-/workspace/.outbox}"
    mkdir -p "$outbox_dir"
    # seq is an ordering hint only; a unique suffix (PID + nanosecond time)
    # prevents the filename collision/overwrite that the racy count-based seq
    # alone caused when two sends ran concurrently.
    seq=$(ls "$outbox_dir"/*.json 2>/dev/null | wc -l)
    seq=$((seq + 1))
    uniq="$$_$(date +%s%N 2>/dev/null || date +%s)"
    filename=$(printf "%04d_%s_%s.json" "$seq" "$to" "$uniq")

    # JSON-encode the content safely. `|| true` keeps a missing/failing jq from
    # aborting the script under `set -e` so the sed fallback below can run.
    encoded=$(printf '%s' "$content" | jq -Rs . 2>/dev/null) || true
    if [ -z "$encoded" ]; then
        # Fallback: escape with sed
        encoded="\"$(printf '%s' "$content" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g' | awk '{printf "%s\\n", $0}' | sed 's/\\n$//')\""
    fi

    # Write to a temp name (not *.json, so the watcher skips it) then atomically
    # rename into place — the watcher never reads a half-written file.
    tmpfile="$outbox_dir/.tmp_${uniq}"
    printf '{"to":"%s","content":%s}\n' "$to" "$encoded" > "$tmpfile"
    mv -f "$tmpfile" "$outbox_dir/$filename"
}

broadcast_message() {
    message="$1"
    if [ -z "$message" ]; then
        echo "Error: No message specified" >&2
        exit 1
    fi

    outbox_dir="${OUTBOX_DIR:-/workspace/.outbox}"
    mkdir -p "$outbox_dir"
    seq=$(ls "$outbox_dir"/*.json 2>/dev/null | wc -l)
    seq=$((seq + 1))
    uniq="$$_$(date +%s%N 2>/dev/null || date +%s)"
    filename=$(printf "%04d_broadcast_%s.json" "$seq" "$uniq")

    # `|| true`: a missing/failing python3 must not abort the script under
    # `set -e`; the sed fallback below handles the encoding.
    encoded=$(printf '%s' "$message" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null) || true
    if [ -z "$encoded" ]; then
        encoded="\"$(printf '%s' "$message" | sed 's/\\/\\\\/g; s/"/\\"/g' | tr '\n' ' ')\""
    fi

    # Temp name then atomic rename (see send_message) — unique suffix avoids the
    # racy-seq collision; the watcher only reads the final *.json.
    tmpfile="$outbox_dir/.tmp_${uniq}"
    printf '{"broadcast":true,"content":%s}\n' "$encoded" > "$tmpfile"
    mv -f "$tmpfile" "$outbox_dir/$filename"
}

# Legacy stdout protocol (kept for backward compatibility)
send_stdout() {
    to="$1"
    shift
    message="$*"

    if [ -z "$to" ] || [ -z "$message" ]; then
        echo "Error: Usage: swarm-msg send-stdout <agent> <message>" >&2
        exit 1
    fi

    echo "${MSG_START}:TO=${to}:START>>"
    echo "$message"
    echo "${MSG_END}"
}

broadcast_stdout() {
    message="$1"
    if [ -z "$message" ]; then
        echo "Error: Usage: swarm-msg broadcast-stdout <message>" >&2
        exit 1
    fi

    echo "${MSG_START}:BROADCAST:START>>"
    echo "$message"
    echo "${MSG_END}"
}

list_agents() {
    if [ -n "$SWARM_TOPOLOGY" ]; then
        echo "Agents you can message:"
        echo "$SWARM_TOPOLOGY" | tr ',' '\n' | sed 's/^/  - /'
    else
        echo "Topology not available."
    fi
}

# Main command dispatch
case "${1:-help}" in
    send)
        shift
        send_message "$@"
        ;;
    broadcast)
        shift
        broadcast_message "$@"
        ;;
    send-stdout)
        shift
        send_stdout "$@"
        ;;
    broadcast-stdout)
        shift
        broadcast_stdout "$@"
        ;;
    list)
        list_agents
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Unknown command: $1" >&2
        echo "Run 'swarm-msg help' for usage" >&2
        exit 1
        ;;
esac
